@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* Безопасная шапка: цвет Primary (синий), все элементы внутри будут белыми *@
    <MudAppBar Elevation="1" Color="Color.Primary">

        @* ЛЕВАЯ ЧАСТЬ: Иконка и номер таски *@
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Inherit" Class="mr-2" />
            <MudText Typo="Typo.caption" Color="Color.Inherit" Style="opacity: 0.7;">Task #5</MudText>
        </div>

        <MudSpacer />

        @* ЦЕНТРАЛЬНАЯ ЧАСТЬ: Название сайта (ровно по центру) *@
        <MudText Typo="Typo.h5" Color="Color.Inherit" Style="font-weight: bold; letter-spacing: 1px;">
            MusicStore
        </MudText>

        <MudSpacer />

        @* ПРАВАЯ ЧАСТЬ: Название компании *@
        <MudText Typo="Typo.body2" Color="Color.Inherit" Style="font-weight: 500;">
            Itransition
        </MudText>

    </MudAppBar>

    @* Основной контент *@
    <MudMainContent Class="pt-16">
        @Body
    </MudMainContent>
</MudLayout>