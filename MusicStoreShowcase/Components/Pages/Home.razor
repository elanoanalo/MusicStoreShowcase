@page "/"
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudPaper Elevation="2" Class="pa-4 mb-4" Style="background-color: #f5f5f5;">
        <MudGrid>

            <MudItem xs="12" sm="3">
                <MudSelect T="string" Label="Language" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="SelectedLanguage">
                    <MudSelectItem Value="@("en")">English</MudSelectItem>
                    <MudSelectItem Value="@("ru")">Русский</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="3">
                <MudTextField T="ulong" Label="Seed" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="CurrentSeed" Format="0" />
            </MudItem>

            <MudItem xs="12" sm="2" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Style="height: 40px;" @onclick="GenerateRandomSeed">
                    Random Seed
                </MudButton>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudText Typo="Typo.body2">Likes (avg): <b>@AvgLikes.ToString("F1")</b></MudText>
                <MudSlider T="double" Min="0.0" Max="10.0" Step="0.1" @bind-Value="AvgLikes" Color="Color.Secondary" />
            </MudItem>

        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-4 text-center" Style="background-color: #e8f5e9;">
        <MudText Typo="Typo.subtitle1" Color="Color.Success">
            <b>System state:</b> Language = @SelectedLanguage | Seed = @CurrentSeed | Likes = @AvgLikes.ToString("F1")
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private string SelectedLanguage { get; set; } = "en";
    private ulong CurrentSeed { get; set; } = 123456789;
    private double AvgLikes { get; set; } = 5.0;

    private void GenerateRandomSeed()
    {
        Random rand = new Random();
        byte[] buffer = new byte[8];
        rand.NextBytes(buffer);
        CurrentSeed = BitConverter.ToUInt64(buffer, 0);
    }
}