@page "/"
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @* 1. TOOLBAR (Элементы управления в одну строку по ТЗ) *@
    <MudPaper Elevation="2" Class="pa-4 mb-4" Style="background-color: #f5f5f5;">
        <MudGrid AlignItems="AlignItems.Center">

            @* Выбор языка через индекс (0 = en, 1 = es) *@
            <MudItem xs="12" sm="3">
                <MudSelect T="int" Label="Language" Variant="Variant.Outlined" Margin="Margin.Dense" Value="SelectedLanguageIndex" ValueChanged="OnLanguageIndexChanged">
                    <MudSelectItem T="int" Value="0">English (US)</MudSelectItem>
                    <MudSelectItem T="int" Value="1">Español</MudSelectItem>
                </MudSelect>
            </MudItem>

            @* Поле ввода Сида с кнопкой-иконкой перемешивания *@
            <MudItem xs="12" sm="3">
                <MudTextField T="ulong" Label="Seed" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Value="CurrentSeed" ValueChanged="OnSeedChanged" Format="0"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Shuffle" OnAdornmentClick="GenerateRandomSeed" />
            </MudItem>

            @* Ползунок средних лайков *@
            <MudItem xs="12" sm="4">
                <div class="d-flex justify-between align-center mb-1">
                    <MudText Typo="Typo.caption" Class="text-muted">Likes (avg):</MudText>
                    <MudText Typo="Typo.body2"><b>@AvgLikes.ToString("F1")</b></MudText>
                </div>
                <MudSlider T="double" Min="0.0" Max="10.0" Step="0.1" Value="AvgLikes" ValueChanged="OnLikesChanged" Color="Color.Primary" />
            </MudItem>

            @* Переключатель режимов отображения с чистыми иконками по ТЗ *@
            <MudItem xs="12" sm="2" Class="d-flex justify-end">
                <MudToggleGroup T="bool" Value="IsTableView" ValueChanged="OnViewModeChanged" Color="Color.Primary" CheckMark="false" Delimiters="true">

                    @* Режим таблицы с пагинацией *@
                    <MudToggleItem Value="true" Title="Table View (Pagination)">
                        <MudIcon Icon="@Icons.Material.Filled.TableRows" />
                    </MudToggleItem>

                    @* Режим галереи с бесконечным скроллом *@
                    <MudToggleItem Value="false" Title="Gallery View (Infinite Scroll)">
                        <MudIcon Icon="@Icons.Material.Filled.GridView" />
                    </MudToggleItem>

                </MudToggleGroup>
            </MudItem>

        </MudGrid>
    </MudPaper>

    @* 2. DATA AREA (Область вывода треков) *@
    @if (IsTableView)
    {
        @* --- РЕЖИМ ТАБЛИЦЫ С ПАГИНАЦИЕЙ --- *@
        <MudTable Items="@CurrentTracks" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1" Dense="true" T="MusicTrack">
            <HeaderContent>
                <MudTh Style="width: 50px;">#</MudTh>
                <MudTh>Song</MudTh>
                <MudTh>Artist</MudTh>
                <MudTh>Album</MudTh>
                <MudTh>Genre</MudTh>
                <MudTh Style="width: 80px;">Likes</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="#">@context.Index</MudTd>
                <MudTd DataLabel="Song">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Class="mr-2 text-muted" />
                        <b>@context.Title</b>
                    </div>
                </MudTd>
                <MudTd DataLabel="Artist">@context.Artist</MudTd>
                <MudTd DataLabel="Album">@context.Album</MudTd>
                <MudTd DataLabel="Genre">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@context.Genre</MudChip>
                </MudTd>
                <MudTd DataLabel="Likes">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" Color="Color.Primary" Class="mr-1" />
                        @context.Likes
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @* Пагинация внизу таблицы *@
        <div class="d-flex justify-center mt-4 mb-6">
            <MudPagination Color="Color.Primary" Count="100" Selected="CurrentPage" SelectedChanged="OnPageChanged" />
        </div>
    }
    else
    {
        @* --- РЕЖИМ ГАЛЕРЕИ С БЕСКОНЕЧНЫМ СКРОЛЛОМ --- *@
        <MudGrid>
            @foreach (var track in CurrentTracks)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="mb-3">
                        <MudCardContent>
                            <div class="d-flex justify-between align-start mb-2">
                                <MudText Typo="Typo.caption" Class="text-muted">#@track.Index</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@track.Genre</MudChip>
                            </div>
                            <MudText Typo="Typo.body1" Style="font-weight: bold;" LineLines="1">@track.Title</MudText>
                            <MudText Typo="Typo.body2" Class="text-muted mb-2" LineLines="1">@track.Artist</MudText>
                            <MudText Typo="Typo.caption" Style="display:block;" Class="mb-2">Album: <i>@track.Album</i></MudText>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" Color="Color.Primary" Class="mr-1" />
                                <MudText Typo="Typo.body2">@track.Likes</MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        @* Индикатор загрузки для бесконечного скролла *@
        <div class="d-flex justify-center my-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
        </div>
    }

    @* Нижняя Debug панель состояния системы (Добавили вывод строки языка для контроля) *@
    <MudPaper Elevation="1" Class="pa-3 text-center mb-4" Style="background-color: #e8f5e9;">
        <MudText Typo="Typo.body2" Color="Color.Success">
            <b>System state:</b> LangIndex = @SelectedLanguageIndex | Locale String = "@SelectedLanguage" | Seed = @CurrentSeed | Likes = @AvgLikes.ToString("F1") | Mode = @(IsTableView ? "Table" : "Gallery") | Page = @CurrentPage
        </MudText>
    </MudPaper>

</MudContainer>

@code {
    private int SelectedLanguageIndex { get; set; } = 0;

    // Вычисляемое свойство возвращает чистую строку "en" или "es"
    private string SelectedLanguage => SelectedLanguageIndex == 1 ? "es" : "en";

    private ulong CurrentSeed { get; set; } = 123456789;
    private double AvgLikes { get; set; } = 5.0;
    private bool IsTableView { get; set; } = true;
    private int CurrentPage { get; set; } = 1;

    private List<MusicTrack> CurrentTracks { get; set; } = new();

    protected override void OnInitialized()
    {
        UpdateData();
    }

    private void UpdateData()
    {
        // Передаем строку локали ("en"/"es") напрямую в генератор
        CurrentTracks = TrackGenerator.GenerateBatch(CurrentSeed, SelectedLanguage, AvgLikes, CurrentPage, pageSize: 10);

        // Форсируем перерисовку UI в InteractiveServer режиме
        StateHasChanged();
    }

    private void ResetNavigation()
    {
        CurrentPage = 1;
        UpdateData();
    }

    private void OnLanguageIndexChanged(int newIndex)
    {
        SelectedLanguageIndex = newIndex;
        ResetNavigation();
    }

    private void OnSeedChanged(ulong newSeed)
    {
        CurrentSeed = newSeed;
        ResetNavigation();
    }

    private void OnLikesChanged(double newLikes)
    {
        AvgLikes = newLikes;
        UpdateData();
    }

    private void OnViewModeChanged(bool isTable)
    {
        IsTableView = isTable;
        ResetNavigation();
    }

    private void OnPageChanged(int page)
    {
        CurrentPage = page;
        UpdateData();
    }

    private void GenerateRandomSeed()
    {
        Random rand = new Random();
        byte[] buffer = new byte[8];
        rand.NextBytes(buffer);
        CurrentSeed = BitConverter.ToUInt64(buffer, 0);
        ResetNavigation();
    }
}